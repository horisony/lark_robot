APP_ID=
APP_SECRET=
LARK_DOMAIN=https://open.feishu.cn
LOG_LEVEL=INFO

# 同一 message_id 去重窗口（秒），防长连接重复投递导致多次回复（默认同一条消息只处理一次，与 event_id 无关）
# DEDUPE_TTL_SEC=600
# 仅排查问题时恢复「message_id + event_id」组合键（默认勿开）
# DEDUPE_INCLUDE_EVENT_ID=1

# 话题/线程内回复会带 parent_id：默认忽略，避免每条跟帖都调一次模型。若要在话题里继续追问，设为 1
# REPLY_TO_THREAD_MESSAGES=1

# 同一会话（同 chat_id）在 N 秒内若连续多条消息，只处理最后一条（0 关闭）。可与去重配合减少连发刷屏
# MESSAGE_DEBOUNCE_SEC=2

# ---------- 模型（至少配置 MiniMax 或 Packy 其一；优先 MiniMax）----------
# MiniMax：Anthropic 兼容 API（官方文档）
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# ANTHROPIC_API_KEY=
# MINIMAX_MODEL=MiniMax-M2.7
# MINIMAX_MAX_TOKENS=4096
# MINIMAX_SYSTEM=You are a helpful assistant.

# 仅调试 MiniMax：设为 1 时 MiniMax 失败不再请求 Packy（便于看清 MiniMax 报错）
# LLM_DISABLE_PACKY_FALLBACK=1

# Packy：OpenAI 兼容 /chat/completions（MiniMax 失败时回退）
PACKY_API_KEY=
PACKY_API_BASE=https://www.packyapi.com/v1
PACKY_MODEL=claude-opus-4-6

# 可选：公司根证书 PEM 路径
# FEISHU_SSL_CA_BUNDLE=/path/to/corp-ca.pem

# 可选：仅调试，关闭 TLS 校验（勿用于生产）
# FEISHU_INSECURE_SSL=1
