APP_ID=
APP_SECRET=
LARK_DOMAIN=https://open.feishu.cn
LOG_LEVEL=INFO

# PackyAPI：POST /v1/chat/completions，Bearer + JSON（与 OpenAI 兼容）
PACKY_API_KEY=
PACKY_API_BASE=https://www.packyapi.com/v1
PACKY_MODEL=claude-opus-4-6

# 可选：公司根证书 PEM 路径
# FEISHU_SSL_CA_BUNDLE=/path/to/corp-ca.pem

# 可选：仅调试，关闭 TLS 校验（勿用于生产）
# FEISHU_INSECURE_SSL=1
