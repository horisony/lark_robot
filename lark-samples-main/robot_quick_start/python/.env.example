APP_ID=
APP_SECRET=
VERIFICATION_TOKEN=
ENCRYPT_KEY=
LARK_HOST=https://open.feishu.cn

# LLM chain: comma-separated, first tried first. Example: minimax,packy
LLM_PROVIDER_ORDER=minimax,packy

# MiniMax (Anthropic-compatible HTTP /v1/messages, no anthropic pip package).
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
ANTHROPIC_API_KEY=
# Optional; default matches Anthropic Messages API.
# ANTHROPIC_VERSION=2023-06-01
# Optional alias for the same key:
# MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_SYSTEM=You are a helpful assistant.
MINIMAX_MAX_TOKENS=4096

# PackyAPI (OpenAI-compatible). Used as fallback when minimax fails.
PACKY_API_KEY=
PACKY_API_BASE=https://www.packyapi.com/v1
PACKY_MODEL=claude-opus-4-6
